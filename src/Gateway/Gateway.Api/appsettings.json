{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Issuer": "nexuscommerce-gateway",
    "Audience": "nexuscommerce",
    "SigningKey": "dev-only-signing-key-change-me-0123456789abcdef",
    "Users": [
      { "Username": "admin", "Password": "admin123", "Role": "admin" },
      { "Username": "demo", "Password": "demo123", "Role": "customer" }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-read": {
        "ClusterId": "catalog",
        "Order": 1,
        "Match": {
          "Path": "/catalog/{**rest}",
          "Methods": [ "GET", "HEAD", "OPTIONS" ]
        },
        "Transforms": [ { "PathRemovePrefix": "/catalog" } ]
      },
      "catalog-write": {
        "ClusterId": "catalog",
        "Order": 2,
        "AuthorizationPolicy": "admin",
        "Match": { "Path": "/catalog/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/catalog" } ]
      },
      "orders": {
        "ClusterId": "orders",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/orders/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/orders" } ]
      },
      "notifications": {
        "ClusterId": "notifications",
        "AuthorizationPolicy": "admin",
        "Match": { "Path": "/notifications/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/notifications" } ]
      },
      "ai": {
        "ClusterId": "ai",
        "Match": { "Path": "/ai/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/ai" } ]
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": { "d1": { "Address": "http://localhost:5101/" } }
      },
      "orders": {
        "Destinations": { "d1": { "Address": "http://localhost:5102/" } }
      },
      "notifications": {
        "Destinations": { "d1": { "Address": "http://localhost:5103/" } }
      },
      "ai": {
        "Destinations": { "d1": { "Address": "http://localhost:5104/" } }
      }
    }
  }
}
